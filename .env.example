# Optional overrides (copy to .env or set in PowerShell before npm run dev)

# Full data root (overrides S: default)
# DOCAPP_DATA_DIR=S:\Documentation App\Data

# Default S: location if DOCAPP_DATA_DIR is not set
# DOCAPP_S_DRIVE_ROOT=S:\Documentation App\Data

# Used when S: drive is not present
# DOCAPP_DATA_FALLBACK=D:\Backup\DocumentationApp\Data
